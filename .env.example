# ============================================================
# The Dog House Pet Salon - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Pet Cam: Galleria Location ---
CAM_GALLERIA_LOCATION="5917 Richmond Ave"
CAM_GALLERIA_ALIAS="Dog Owners"
CAM_GALLERIA_REGISTER_MODE="IP/Domain"
CAM_GALLERIA_IP="your-ip-address-here"
CAM_GALLERIA_PORT="7000"
CAM_GALLERIA_USER="your-username-here"
CAM_GALLERIA_PASSWORD="your-password-here"

# --- Pet Cam: Washington Ave / Memorial Location ---
CAM_WASHINGTON_LOCATION="6434 Washington Ave"
CAM_WASHINGTON_ALIAS="DHPS Washington"
CAM_WASHINGTON_REGISTER_MODE="IP/Domain"
CAM_WASHINGTON_IP="your-ip-address-here"
CAM_WASHINGTON_PORT="8000"
CAM_WASHINGTON_USER="your-username-here"
CAM_WASHINGTON_PASSWORD="your-password-here"

# --- SMTP (for appointment & grooming school form emails) ---
# If these are not set, form submissions will be logged to the
# server console as a fallback so no data is ever lost.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@thedoghouseps.com"

# --- Google Analytics 4 ---
# Replace G-XXXXXXXXXX with your real GA4 Measurement ID from
# https://analytics.google.com/ > Admin > Data Streams > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
